{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Atlas API (main:app)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8010",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "LLM_BACKEND": "local",
        "OLLAMA_MODEL": "deepseek-coder:6.7b",
        "OLLAMA_HOST": "http://127.0.0.1:11434",
        "PYTHONUNBUFFERED": "1"
      }
    }
  ]
}
