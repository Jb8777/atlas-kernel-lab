# Backend selection
LLM_BACKEND=local

# Local Ollama
OLLAMA_MODEL=deepseek-coder:6.7b
OLLAMA_HOST=http://localhost:11434

# LLM request timeout in seconds (default: 120)
LLM_TIMEOUT_S=120

# Optional cloud fallback
OPENROUTER_API_KEY=

# Application settings (used by core/config_loader.py)
APP_ENV=development
APP_NAME=AtlasKernel
LOG_LEVEL=INFO

# Path to model router config (default: config/model_router.json)
CONFIG_PATH=

# Directory for log files (default: logs/)
LOGS_DIR=

# Set to 1 to disable output buffering in Python (used by .vscode/launch.json)
PYTHONUNBUFFERED=1
